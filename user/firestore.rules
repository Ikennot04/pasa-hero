rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users collection - authenticated users can read/write their own data
    match /users/{userId} {
      // Allow read if user is authenticated and accessing their own document
      allow read: if request.auth != null && request.auth.uid == userId;
      // Allow create if user is authenticated (for new account creation)
      allow create: if request.auth != null && request.auth.uid == userId;
      // Allow update if user is authenticated and updating their own document
      allow update: if request.auth != null && request.auth.uid == userId;
      // Allow delete if user is authenticated and deleting their own document
      allow delete: if request.auth != null && request.auth.uid == userId;
    }
    
    // OTP verifications - allow anyone to create/read (for email verification before account creation)
    match /otp_verifications/{email} {
      allow read: if true; // Allow reading to verify OTP
      allow create: if true; // Allow creating OTP (before user is authenticated)
      allow update: if true; // Allow updating to mark as verified
      allow delete: if true; // Allow deleting expired OTPs
    }

    // Routes collection - route definitions with bus stop coordinates (e.g. Route1)
    // Authenticated users (operators) can read and write so Route1 can be saved and loaded
    match /routes/{routeId} {
      allow read, create, update: if request.auth != null;
      allow delete: if false;
    }

    // route_code collection - driver route codes: point A, point B, bus stops along the way
    match /route_code/{routeCodeId} {
      allow read, create, update, delete: if request.auth != null;
    }

    // driver_status - active driver per route, is_free_ride, free_ride_until
    match /driver_status/{documentId} {
      allow read, create, update, delete: if request.auth != null;
    }

    // Live operator GPS for "buses near you" (passenger reads; operator writes own doc)
    match /operator_locations/{operatorId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null && request.auth.uid == operatorId;
    }
    
    // Default deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
